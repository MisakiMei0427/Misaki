    window.deleteAccount = (id) => { if(!isMaster())return; if(id==='1')return alert('不能删除主人'); if(confirm('确定删除？')){const d=loadData();delete d.accounts[id];delete d.nicknames[id];delete d.nicknameMeta[id];saveData(d);if(viewingUserId===id)viewingUserId=currentUserId;render();} };
    window.saveNickname = () => { const n=document.getElementById('nicknameInput')?.value.trim(); if(!n)return; const r=setNickname(currentUserId,n); if(!r.success)alert(r.message); render(); };
    window.postMessage = (tid) => { const t=document.getElementById('msgInput').value.trim(); if(!t||t.length>200)return; updateAccount(tid,a=>{a.messages.push({from:currentUserId,text:t,time:Date.now()});}); render(); };
    window.deleteMessage = (aid,idx) => { const d=loadData(); const a=d.accounts[aid]; if(!a)return; if(currentUserId===aid||a.messages[idx]?.from===currentUserId){a.messages.splice(idx,1);saveData(d);render();} };

    theme = localStorage.getItem('delta_theme')||'light';
    if(theme==='dark') document.documentElement.classList.add('dark-mode');
    const params=new URLSearchParams(window.location.search);
    const shareWeapon=params.get('weapon'), shareIdx=parseInt(params.get('idx'));
    if(shareWeapon&&!isNaN(shareIdx)){
        viewingUserId=Object.keys(loadData().accounts).find(id=>loadData().accounts[id].codes[shareWeapon]?.[shareIdx])||'share_view';
        currentUserId=null;
        searchFilter='';
    }
    render();
})();
</script>
</body>
</html>