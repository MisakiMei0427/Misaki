    function loadData() {
        const raw = localStorage.getItem(STORAGE);
        if (raw) {
            const data = JSON.parse(raw);
            if (!data.nicknameMeta) data.nicknameMeta = {};
            if (!data.passwords) data.passwords = {};
            if (!data.announcements) data.announcements = [];
            Object.values(data.accounts).forEach(acc => {
                Object.keys(acc.codes).forEach(weapon => {
                    acc.codes[weapon] = (acc.codes[weapon] || []).map(c => {
                        if (typeof c === 'string') return { code: c, tags: [], likes: 0, likedBy: [], comments: [], history: [], value: '' };
                        if (!c.tags) c.tags = [];
                        if (!c.likedBy) c.likedBy = [];
                        if (!c.comments) c.comments = [];
                        if (!c.history) c.history = [];
                        if (c.value === undefined) c.value = '';
                        return c;
                    });
                });
            });
            return data;
        }
        return { accounts: {}, nicknames: {}, nicknameMeta: {}, passwords: {}, announcements: [] };
    }
    function saveData(data) { localStorage.setItem(STORAGE, JSON.stringify(data)); }
    function getAccount(id) {
        const data = loadData();
        if (!data.accounts[id]) { data.accounts[id] = { codes: {}, copyLog: [], accessLog: [], messages: [] }; saveData(data); }
