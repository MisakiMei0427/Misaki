        wheel.results.push(result);
        saveData(data);
        document.getElementById('wheelResult').textContent = '';
        const spinBtn = document.getElementById('spinBtn');
        if (spinBtn) { spinBtn.disabled = true; spinBtn.textContent = '旋转中...'; }
        startSpinAnimation(result);
    };
