        .btn { padding: 7px 14px; border-radius: 8px; border: none; cursor: pointer; font-weight: 600; font-size: 12px; background: var(--accent-light); color: var(--text); transition: 0.2s; display: inline-flex; align-items: center; gap: 4px; white-space: nowrap; border: 1px solid var(--border); }
        .btn-primary { background: var(--accent); color: white; border: none; }
        .btn-primary:hover { opacity: 0.9; }
        .btn:hover { background: var(--hover-bg); }
        .btn-sm { padding: 4px 10px; font-size: 10px; }
        .btn-danger { background: #fee2e2; color: #b91c1c; border-color: #fecaca; }
        .btn-danger:hover { background: #fecaca; }
        .search-area { display: flex; gap: 6px; align-items: center; }
        .search-area input { padding: 7px 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px; width: 160px; background: var(--input-bg); color: var(--text); }
        .main-grid { display: flex; gap: 16px; align-items: flex-start; }
        .weapon-panel { flex: 2; min-width: 0; }
        .side-panel { flex: 1; min-width: 260px; display: flex; flex-direction: column; gap: 16px; }
        .section-card { background: var(--card-bg); border-radius: 12px; box-shadow: var(--shadow); overflow: hidden; border: 1px solid var(--border); }
        .card-header { padding: 12px 16px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
        .card-header h3 { font-size: 15px; font-weight: 700; display: flex; align-items: center; gap: 6px; }
        .card-body { padding: 10px 16px 16px; }
        .tab-row { display: flex; gap: 4px; margin-bottom: 12px; }
        .tab-btn { padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border); background: var(--card-bg); cursor: pointer; font-size: 11px; font-weight: 600; color: var(--text); }
        .tab-btn.active { background: var(--accent); color: white; border-color: var(--accent); }
        .category-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; cursor: pointer; user-select: none; border-bottom: 1px solid var(--border); margin-bottom: 8px; }
