        .weapon-block { margin-bottom: 12px; padding: 10px; background: var(--bg); border-radius: 8px; border: 1px solid var(--border); }
        .weapon-check { margin-right: 8px; }
        .weapon-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
        .weapon-name { font-weight: 700; font-size: 14px; display: flex; align-items: center; gap: 6px; }
        .weapon-icon { font-size: 18px; }
        .weapon-name small { font-weight: 400; font-size: 10px; color: var(--text-secondary); display: block; }
        .code-list { display: flex; flex-direction: column; gap: 8px; }
        .code-row { display: flex; align-items: flex-start; gap: 8px; flex-wrap: wrap; }
        .code-input { flex: 1; padding: 6px 10px; border: 1px solid var(--border); border-radius: 6px; font-size: 12px; font-family: monospace; background: var(--input-bg); color: var(--text); min-width: 150px; }
        .code-input:focus { border-color: var(--accent); outline: none; }
        .copy-btn { background: var(--card-bg); border: 1px solid var(--border); padding: 5px 10px; border-radius: 6px; cursor: pointer; font-size: 11px; color: var(--text); }
        .copy-btn:hover { background: var(--hover-bg); }
