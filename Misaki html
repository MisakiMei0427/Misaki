        .share-btn:hover { background: #bfdbfe; }
        .like-btn { background: none; border: none; cursor: pointer; font-size: 14px; padding: 2px 4px; }
        .delete-code-btn { background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 14px; padding: 2px 6px; }
        .delete-code-btn:hover { color: #ef4444; }
        .add-code-btn { background: none; border: 1px dashed var(--border); color: var(--text-secondary); padding: 4px 12px; border-radius: 6px; cursor: pointer; font-size: 11px; margin-top: 4px; display: inline-block; }
        .add-code-btn:hover { border-color: var(--accent); color: var(--accent); }
        .tag-input { width: 100px; padding: 2px 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 10px; background: var(--input-bg); color: var(--text); }
        .tag { background: var(--tag-bg); color: var(--tag-text); padding: 1px 6px; border-radius: 4px; font-size: 10px; margin-right: 2px; }
        .value-input { width: 70px; padding: 2px 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 10px; background: var(--input-bg); color: var(--text); }
        .comment-area { margin-top: 4px; width: 100%; }
        .comment-input { width: 100%; padding: 4px; border: 1px solid var(--border); border-radius: 4px; font-size: 11px; background: var(--input-bg); color: var(--text); margin-top: 2px; }
        .comment-item { font-size: 10px; padding: 2px 0; display: flex; justify-content: space-between; align-items: flex-start; }
        .comment-item .meta { color: var(--text-secondary); }
        .history-select { font-size: 10px; padding: 2px 4px; border: 1px solid var(--border); border-radius: 4px; background: var(--input-bg); color: var(--text); }
        .rank-list { background: var(--bg); border-radius: 8px; padding: 10px; }
        .rank-item { display: flex; justify-content: space-between; font-size: 12px; padding: 4px 0; }
        .rank-item .name { font-weight: 600; }
        .message-area { background: var(--bg); border-radius: 8px; padding: 12px; max-height: 250px; overflow-y: auto; }
        .msg-item { border-bottom: 1px solid var(--border); padding: 6px 0; font-size: 12px; display: flex; justify-content: space-between; align-items: flex-start; }
        .msg-item .meta { color: var(--text-secondary); font-size: 10px; }
        textarea { width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 6px; resize: vertical; font-size: 12px; background: var(--input-bg); color: var(--text); }
        .strength-tag { font-size: 9px; padding: 2px 6px; border-radius: 4px; background: #e2e8f0; color: #475569; margin-left: 4px; font-weight: 500; }
        .strength-tag.s-plus { background: #fef3c7; color: #92400e; }
        .strength-tag.s { background: #fce7f3; color: #9d174d; }
        .strength-tag.a-plus { background: #dbeafe; color: #1e40af; }
        .strength-tag.a { background: #e0e7ff; color: #3730a3; }
        .strength-tag.b { background: #f3f4f6; color: #4b5563; }
        .strength-tag.c { background: #f9fafb; color: #9ca3af; }

        .wheel-section { margin-top: 8px; }
        .wheel-flex { display: flex; align-items: center; justify-content: center; gap: 24px; flex-wrap: wrap; }
        .wheel-canvas-box { width: 320px; height: 320px; flex-shrink: 0; }
        .wheel-control { display: flex; flex-direction: column; align-items: center; min-width: 120px; }
        .wheel-info { font-size: 15px; margin-top: 12px; text-align: center; font-weight: 600; }
        .announcement-area { background: var(--bg); border-radius: 8px; padding: 12px; max-height: 200px; overflow-y: auto; }
        .announce-item { border-bottom: 1px solid var(--border); padding: 6px 0; font-size: 12px; }
        .announce-item .meta { color: var(--text-secondary); font-size: 10px; }
        @media (max-width: 800px) {
            .main-grid { flex-direction: column; } .side-panel { min-width: 0; }
            .wheel-flex { flex-direction: column; gap: 12px; }
        }
    </style>
</head>
