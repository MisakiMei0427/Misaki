        ]}
    ];
    const WEAPON_ICON_MAP = {};
    WEAPON_CATEGORIES.forEach(cat => cat.weapons.forEach(w => { WEAPON_ICON_MAP[w.alias] = cat.icon; }));

    const WHEEL_POOL = [];
    WEAPON_CATEGORIES.forEach(cat => {
        cat.weapons.forEach(w => {
            const isMain = ['突击步枪','冲锋枪','精确射手步枪','轻机枪'].includes(cat.cat);
            const weight = isMain ? 9 : 1;
            for (let i = 0; i < weight; i++) WHEEL_POOL.push(w.alias);
        });
    });

    let currentUserId = null, viewingUserId = null, searchFilter = '', categoryCollapsed = {}, rankingTab = 'day', theme = 'light';
    let batchMode = false, selectedWeapons = {};
    let wheelAnimation = null, wheelRotation = 0, wheelResultText = '', wheelHighlightIndex = -1;

    function isOwnerMode() { return currentUserId && viewingUserId === currentUserId; }
    function isVisitorMode() { return currentUserId && viewingUserId && viewingUserId !== currentUserId; }
    function isMaster() { return currentUserId === '1'; }
    function getTodayStart() { const d = new Date(); d.setHours(0,0,0,0); return d.getTime(); }
    function getNickname(id) { return loadData().nicknames[id] || null; }
    function isNicknameFixed(id) { const data = loadData(); return data.nicknames[id] && (data.nicknameMeta[id] || 0) >= 1; }
    function setNickname(id, name) {
        const data = loadData();
        if (data.nicknames[id] && (data.nicknameMeta[id] || 0) >= 1) return { success: false, message: '昵称已固定' };
        for (const [k, v] of Object.entries(data.nicknames)) { if (k !== id && v === name) return { success: false, message: '昵称重复' }; }
        data.nicknames[id] = name;
        data.nicknameMeta[id] = data.nicknames[id] ? (data.nicknameMeta[id] || 0) + 1 : 0;
        saveData(data);
        return { success: true };
    }
    function hasPassword(id) { return !!loadData().passwords[id]; }
    function checkPassword(id, password) { return loadData().passwords[id] === password; }
    function setPassword(id, password) {
        const data = loadData();
        if (!/^(?=.*[a-zA-Z])(?=.*\d)[a-zA-Z\d]{1,16}$/.test(password)) return { success: false, message: '密码需英文数字结合，最大16位' };
        data.passwords[id] = password;
        saveData(data);
        return { success: true };
    }
    function sortWeaponsByUsage(weapons, copyLog, start) {
        const cnt = {}; (copyLog||[]).filter(l => l.time >= start).forEach(l => cnt[l.weapon] = (cnt[l.weapon]||0)+1);
        return [...weapons].sort((a,b) => (cnt[b.alias]||0) - (cnt[a.alias]||0));
    }
    function escHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function parseSearchValue(filter) {
        const match = filter.match(/^(.+?)\s*>=(\d+)$/);
        if (match) return { weapon: match[1].trim(), value: parseInt(match[2]) };
        return { weapon: filter, value: null };
    }
    function getWheelData() {
        const data = loadData();
        const today = new Date().toDateString();
        if (!data.wheel || data.wheel.date !== today) {
            const shuffled = [...WHEEL_POOL].sort(() => Math.random() - 0.5);
            const unique = [...new Set(shuffled)].slice(0, 40);
            data.wheel = { date: today, weapons: unique, results: [] };
            saveData(data);
        }
        return data.wheel;
    }
    function drawWheel(weapons, rotation = 0, highlightIndex = -1) {
        const canvas = document.getElementById('wheelCanvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const num = weapons.length;
        const angle = (2 * Math.PI) / num;
        const radius = canvas.width / 2 - 10;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (let i = 0; i < num; i++) {
            const startAngle = i * angle + rotation;
            const endAngle = startAngle + angle;
            ctx.beginPath();
            ctx.moveTo(canvas.width/2, canvas.height/2);
            ctx.arc(canvas.width/2, canvas.height/2, radius, startAngle, endAngle);
            if (i === highlightIndex) {
                ctx.fillStyle = '#fbbf24';
                ctx.shadowColor = '#f59e0b';
                ctx.shadowBlur = 12;
            } else {
                ctx.fillStyle = i % 2 === 0 ? '#e2e8f0' : '#f8fafc';
                ctx.shadowColor = 'transparent';
                ctx.shadowBlur = 0;
            }
            ctx.fill();
            ctx.shadowColor = 'transparent';
            ctx.shadowBlur = 0;
            ctx.strokeStyle = '#94a3b8';
            ctx.stroke();
            ctx.save();
            ctx.translate(canvas.width/2, canvas.height/2);
            ctx.rotate(startAngle + angle/2);
            ctx.textAlign = 'right';
            ctx.fillStyle = '#1e293b';
            ctx.font = '11px "PingFang SC","Microsoft YaHei",sans-serif';
            const label = weapons[i].length > 12 ? weapons[i].substring(0,12)+'…' : weapons[i];
            ctx.fillText(label, radius - 14, 4);
            ctx.restore();
        }
    }
    function startSpinAnimation(targetWeapon) {
        const data = loadData();
        const wheel = getWheelData();
        const idx = wheel.weapons.indexOf(targetWeapon);
        if (idx === -1) return;
        const num = wheel.weapons.length;
        const anglePerSegment = (2 * Math.PI) / num;
        const targetAngle = (2 * Math.PI) - (idx * anglePerSegment + anglePerSegment/2) + Math.PI*2*5;
        const startRotation = wheelRotation;
        const duration = 2000;
        const startTime = performance.now();
        wheelHighlightIndex = -1;
        cancelAnimationFrame(wheelAnimation);
        function animate(now) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            wheelRotation = startRotation + targetAngle * eased;
            drawWheel(wheel.weapons, wheelRotation, -1);
            if (progress < 1) {
                wheelAnimation = requestAnimationFrame(animate);
            } else {
                wheelAnimation = null;
                wheelResultText = targetWeapon;
                wheelHighlightIndex = idx;
                drawWheel(wheel.weapons, wheelRotation, idx);
                document.getElementById('wheelResult').textContent = `来一把美滋滋的${targetWeapon}`;
                const spinBtn = document.getElementById('spinBtn');
                if (spinBtn) { spinBtn.disabled = false; spinBtn.textContent = '🎲 转动'; }
            }
        }
        wheelAnimation = requestAnimationFrame(animate);
    }
